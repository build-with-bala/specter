# ============================================================
#  Specter — environment variables
#  Copy this file to .env and fill in your keys.
# ============================================================

# ── AI Providers ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Browser ───────────────────────────────────────────────────
# Path to Chrome/Chromium binary (auto-detected if not set)
# CHROME_PATH=/usr/bin/google-chrome

# ── Specter overrides ────────────────────────────────────────
# SPECTER_HEADLESS=true
# SPECTER_DEBUG_PORT=9222
# SPECTER_PROXY=http://127.0.0.1:8080
# SPECTER_STEALTH=true
# SPECTER_LOG_LEVEL=DEBUG
